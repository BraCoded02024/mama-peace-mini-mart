generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING_REVIEW
  AWAITING_PAYMENT
  PAYMENT_CONFIRMED
  READY_FOR_PICKUP
  RIDER_ASSIGNED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum RiderStatus {
  ACTIVE
  INACTIVE
}

enum PaymentMethod {
  PAYSTACK
  MTN_MOMO
}

model Order {
  id                   String      @id @default(cuid())
  referenceNumber      String      @unique
  customerName         String
  phoneNumber          String
  customerEmail        String?
  gpsAddress           String
  locationDescription  String?
  itemsRequested       String
  specialInstructions  String?
  status               OrderStatus @default(PENDING_REVIEW)
  subtotal             Float?
  deliveryFee          Float?
  serviceFee           Float?
  totalAmount          Float?
  paymentMethod        PaymentMethod?
  adminMessage         String?
  verificationCode     String?
  transactionReference String?
  assignedRiderId      String?
  assignedRider        Rider?      @relation(fields: [assignedRiderId], references: [id], onDelete: SetNull)
  assignedAt           DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  items                OrderItem[]
}

model OrderItem {
  id         String @id @default(cuid())
  orderId    String
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  itemName   String
  quantity   Int
  unitPrice  Float
  totalPrice Float
}

model Complaint {
  id          String   @id @default(cuid())
  name        String
  phoneNumber String
  category    String
  message     String
  status      String   @default("NEW")
  createdAt   DateTime @default(now())
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Rider {
  id              String      @id @default(cuid())
  name            String
  phone           String      @unique
  pinHash         String
  area            String
  motorbikeNumber String?
  status          RiderStatus @default(ACTIVE)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  orders          Order[]
}
